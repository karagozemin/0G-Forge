{
  "name": "@kaptan_web3/og-cli",
  "version": "0.1.0",
  "description": "Terminal-native companion for building and shipping 0G app MVPs.",
  "private": false,
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./template-utils": {
      "import": "./dist/template-utils.js",
      "require": "./dist/template-utils.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "og": "dist/index.js"
  },
  "files": [
    "dist",
    "assets/templates",
    "package.json"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist",
    "prepare:assets": "node ./scripts/prepare-package-assets.mjs",
    "build": "pnpm run clean && tsup",
    "prepack": "pnpm run build && pnpm run prepare:assets",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json",
    "test": "echo \"no tests yet\""
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@og/compute-client": "workspace:*",
    "@og/core": "workspace:*",
    "@og/deploy-vercel": "workspace:*",
    "@og/storage": "workspace:*",
    "tsup": "^8.2.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
